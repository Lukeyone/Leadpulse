# Copy this file to .env and add your own restricted API keys.
# The real .env file is ignored by Git and must never be committed.

SERPER_API_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Bind to the local machine by default. Do not change this to 0.0.0.0
# unless you understand and accept the network exposure.
HOST=127.0.0.1
PORT=8080

# Optional request metadata logging. Request bodies, prompts, URLs, and keys
# are never deliberately logged by the application.
LOG_REQUESTS=false
